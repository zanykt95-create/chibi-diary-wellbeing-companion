# =============================================================================
# Chibi Diary & Wellbeing Companion — Environment Variables Template
#
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control — only this .env.example.
# =============================================================================

# -----------------------------------------------------------------------------
# Google AI / Gemini (required for AI Studio / local dev)
# Get your key at: https://aistudio.google.com/
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=your_google_api_key_here

# Set to False for AI Studio (dev), True for Vertex AI (prod)
GOOGLE_GENAI_USE_VERTEXAI=False

# -----------------------------------------------------------------------------
# Google Cloud Project (required when GOOGLE_GENAI_USE_VERTEXAI=True)
# -----------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=your_project_id_here
GOOGLE_CLOUD_LOCATION=us-central1

# -----------------------------------------------------------------------------
# MCP Image Generation Server (Day 2 — chibi art generation)
# Output directory for generated chibi images (relative to project root)
# -----------------------------------------------------------------------------
CHIBI_IMAGES_DIR=./output/chibi_images

# -----------------------------------------------------------------------------
# Database
# Path to the SQLite file where diary entries are persisted.
# Relative paths are resolved from the project root.
# -----------------------------------------------------------------------------
DATABASE_PATH=./chibi_diary.db
